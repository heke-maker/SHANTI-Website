  <%# --- 2. ヒーローエリア --- %>
  <div class="detail-hero">
    <div class="detail-hero-overlay">
      <img src="<%= image_url %>" alt="<%= title %>">
    </div>
    <div class="detail-hero-content">
      <div class="detail-badge"><%= category %></div>
      <h1 class="detail-main-title"><%= title %></h1>
    </div>
  </div>

  <%# --- 3. メインコンテンツ --- %>
  <div class="detail-main-body">
    <div class="detail-section">
      <h2 class="detail-sub-title">ACTIVITY DETAIL <span>- 活動詳細 -</span></h2>
      
      <div class="detail-description">
        <%= description %>
      </div>
    </div>

    <div class="detail-actions">
      <%= link_to activities_path, class: "back-btn" do %>
        <span>←</span> 活動一覧に戻る
      <% end %>
    </div>
  </div>
</div>
